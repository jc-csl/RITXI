# Ritxi FastAPI v5.2
RITXI_MODE=reachy_daemon
RITXI_ROBOT_HOST=127.0.0.1

# LLM local
RITXI_LLM_PROVIDER=ollama
RITXI_OLLAMA_URL=http://127.0.0.1:11434
RITXI_OLLAMA_MODEL=gemma3:1b
RITXI_LLM_STREAMING_ENABLED=true
RITXI_LLM_TEMPERATURE=0.25
RITXI_LLM_MAX_TOKENS=40
RITXI_LLM_TIMEOUT_S=12
RITXI_OLLAMA_NUM_CTX=640
RITXI_OLLAMA_TOP_K=20
RITXI_OLLAMA_TOP_P=0.85
RITXI_OLLAMA_REPEAT_PENALTY=1.15

# Micro/audio PC recomendados para conversación natural
RITXI_STT_PROVIDER=browser
RITXI_TTS_PROVIDER=browser

# Conversación y seguridad de turnos
RITXI_ECHO_GUARD_ENABLED=true
RITXI_ECHO_COOLDOWN_S=0.8
RITXI_SYNCHRONIZE_TURNS_DEFAULT=true
RITXI_FIRST_SENTENCE_TTS_STREAMING=false

# Carácter inicial
RITXI_DEFAULT_CHARACTER_ID=ritxi_tutor_comunicacion_di

# Movimiento durante habla
RITXI_SPEECH_MOTION_ENABLED_DEFAULT=true
RITXI_SPEECH_MOTION_INTENSITY_DEFAULT=0.72
RITXI_IDLE_ENABLED_DEFAULT=false

# Defaults UI
RITXI_USE_OUTPUT_AUDIO_DEFAULT=true
RITXI_USE_INPUT_MICROPHONE_DEFAULT=true
RITXI_USE_ROBOT_MOTION_DEFAULT=true
RITXI_USE_EMOTION_TAGS_DEFAULT=true
RITXI_DEBUG_DEFAULT=true
